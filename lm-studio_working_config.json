{
  "mcpServers": {
    "mcp-server-qdrant": {
      "command": "/path/to/mcp-server-qdrant-enhanced/.venv/bin/mcp-server-qdrant",
      "cwd": "/path/to/mcp-server-qdrant-enhanced",
      "args": ["--transport", "stdio"],
      "env": {
        "QDRANT_MODE": "server",
        "QDRANT_URL": "http://127.0.0.1:6333",
        "EMBEDDING_PROVIDER": "fastembed",
        "EMBEDDING_MODEL": "sentence-transformers/all-MiniLM-L6-v2",
        "COLLECTION_NAME": "lm_studio_memories",
        "QDRANT_ENABLE_COLLECTION_MANAGEMENT": "true",
        "QDRANT_ENABLE_RESOURCES": "true",
        "QDRANT_DEFAULT_VECTOR_SIZE": "384"
      }
    }
  }
}
